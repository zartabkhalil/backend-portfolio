// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//****enums*****
enum Role {
  ADMIN
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum MediaType {
  IMAGE
  VIDEO
}

enum REACTION {
  LIKE
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  REPLY
}

//****Models*****
model User {
  id            Int           @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String        @unique
  Role          Role          @default(USER)
  AccountStatus AccountStatus @default(PENDING)
  password      String
  otp           String?
  otpExpiry     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  //reverse realtions
  profile       Profile?
  posts         Post[]
  postLikes     PostLike[]
  comments      Comment[]
  commentLikes  CommentLike[]
  // Users that follow me
  followers     Follower[]    @relation("UserFollowers")

  // Users I follow
  following     Follower[]     @relation("UserFollowing")
  // Notifications received
  notifications Notification[] @relation("UserNotifications")

  // Notifications sent
  sentNotifications Notification[] @relation("SenderNotifications")
}

model Profile {
  id          Int      @id @default(autoincrement())
  //Relation
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  username    String
  bio         String
  avatar      String
  converImage String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id        Int      @id @default(autoincrement())
  //Relation
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //reverse realtions
  postMedia     PostMedia[]
  postLikes     PostLike[]
  comments      Comment[]
  postHashtags  PostHashtag[]
  notifications Notification[]
}

model PostMedia {
  id        Int       @id @default(autoincrement())
  //Relation
  postId    Int
  post      Post      @relation(fields: [postId], references: [id])
  url       String
  type      MediaType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PostLike {
  id Int @id @default(autoincrement())

  //Relation
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  //Relation
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  reaction  REACTION
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id     Int  @id @default(autoincrement())
  //Relation
  userId Int
  user   User @relation(fields: [userId], references: [id])
  //Relation
  postId Int
  post   Post @relation(fields: [postId], references: [id])

  //self relation(REPLIES)
  parentId Int?
  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id])

  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())

  //reverse realtions
  commentLikes  CommentLike[]
  notifications Notification[]
}

model CommentLike {
  id     Int  @id @default(autoincrement())
  //Relation
  userId Int
  user   User @relation(fields: [userId], references: [id])

  //Relation
  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id])

  reaction  REACTION
  createdAt DateTime @default(now())
}

model Follower {
  id Int @id @default(autoincrement())

  followerId Int
  follower   User @relation("UserFollowing", fields: [followerId], references: [id])

  followingId Int
  following   User @relation("UserFollowers", fields: [followingId], references: [id])

  createdAt DateTime @default(now())
  userId    Int?
}

model Hashtag {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  createdAt    DateTime      @default(now())
  postHashtags PostHashtag[]
}

model PostHashtag {
  id Int @id @default(autoincrement())

  postId Int
  post   Post @relation(fields: [postId], references: [id])

  hashtagId Int
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, hashtagId])
}

model Notification {
  id Int @id @default(autoincrement())

  // User who receives the notification
  userId Int
  user   User @relation("UserNotifications", fields: [userId], references: [id])

  // User who triggered the notification
  senderId Int
  sender   User @relation("SenderNotifications", fields: [senderId], references: [id])

  // Notification type
  type NotificationType

  // Optional related post
  postId Int?
  post   Post? @relation(fields: [postId], references: [id])

  // Optional related comment
  commentId Int?
  comment   Comment? @relation(fields: [commentId], references: [id])

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}
